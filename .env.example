# ─── Supabase ─────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Supabase Auth — Google OAuth ─────────────────────────────────────────
# Set these in Supabase Dashboard → Auth → Providers → Google
SUPABASE_AUTH_GOOGLE_CLIENT_ID=<google-oauth-client-id>
SUPABASE_AUTH_GOOGLE_SECRET=<google-oauth-client-secret>

# ─── LiteLLM (self-hosted on Railway) ────────────────────────────────────
# Internal service — not exposed to the browser
LITELLM_BASE_URL=https://<your-litellm-railway-url>
LITELLM_MASTER_KEY=<litellm-master-key>

# ─── Runtime (Python/LangGraph on Railway) ───────────────────────────────
RUNTIME_BASE_URL=https://<your-runtime-railway-url>
RUNTIME_API_KEY=<shared-secret-between-web-and-runtime>

# ─── Inngest ──────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=<inngest-event-key>
INNGEST_SIGNING_KEY=<inngest-signing-key>

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
